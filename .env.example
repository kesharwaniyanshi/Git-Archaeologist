# Groq API Configuration
# Get your free API key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Vector backend configuration (faiss or pgvector)
VECTOR_BACKEND=pgvector

# PostgreSQL connection string for pgvector backend
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/git_archaeologist
# When VECTOR_BACKEND=pgvector, commit indexes are persisted to repositories/commits tables.

# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your_supabase_key_here
