# Groq API Configuration
# Get your free API key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Vector backend configuration (faiss or pgvector)
VECTOR_BACKEND=pgvector

# PostgreSQL connection string for pgvector backend
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/git_archaeologist
# When VECTOR_BACKEND=pgvector, commit indexes are persisted to repositories/commits tables.

# GitHub OAuth (Phase 5)
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
GITHUB_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/auth/github/callback
FRONTEND_URL=http://localhost:3000

# Session signing key for OAuth cookie session
APP_SESSION_SECRET=change_this_to_a_long_random_secret

# Optional GitHub API token for repository commit fetching.
# If unset, unauthenticated limits apply (about 60 requests/hour per IP).
GITHUB_TOKEN=your_github_personal_access_token

# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your_supabase_key_here
